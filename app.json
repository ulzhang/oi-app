{
  "expo": {
    "name": "Oi",
    "slug": "oi",
    "scheme": "oi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "platforms": ["ios"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oi.walkpip",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Oi uses your rear camera to show what's ahead of you in a floating window, so you can see where you're walking. The camera feed stays on your device and is never recorded or transmitted."
      }
    },
    "plugins": [
      "expo-router",
      "./plugins/withOiEntitlements",
      "./plugins/withOiWidget"
    ]
  }
}
